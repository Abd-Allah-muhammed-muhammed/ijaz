<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
            <directory>Modules/Classifieds/tests/Feature</directory>
            <directory>Modules/Catalog/tests/Feature</directory>
            <directory>Modules/Opportunity/tests/Feature</directory>
            <directory>Modules/Opportunity/tests/Unit</directory>
            <directory>Modules/Guarantor/tests/Unit</directory>
            <directory>Modules/Guarantor/tests/Feature</directory>
        </testsuite>
        <testsuite name="Chat">
            <directory suffix="Test.php">./Modules/Chat/tests</directory>
        </testsuite>
        <testsuite name="Wallet">
            <directory suffix="Test.php">./Modules/Wallet/tests</directory>
        </testsuite>
        <testsuite name="Payment">
            <directory suffix="Test.php">./Modules/Payment/tests</directory>
        </testsuite>
        <testsuite name="Sms">
            <directory suffix="Test.php">./Modules/Sms/tests</directory>
        </testsuite>
        <testsuite name="Geo">
            <directory suffix="Test.php">./Modules/Geo/tests</directory>
        </testsuite>
        <testsuite name="Jobs">
            <directory suffix="Test.php">./Modules/Jobs/tests</directory>
        </testsuite>
        <testsuite name="Cms">
            <directory suffix="Test.php">./Modules/Cms/tests</directory>
        </testsuite>
        <testsuite name="Support">
            <directory suffix="Test.php">./Modules/Support/tests</directory>
        </testsuite>
        <testsuite name="Marketplace">
            <directory suffix="Test.php">./Modules/Marketplace/tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
            <directory>Modules/Classifieds</directory>
            <directory>Modules/Catalog</directory>
            <directory>Modules/Opportunity</directory>
            <directory>Modules/Guarantor</directory>
            <directory>Modules/Chat</directory>
            <directory>Modules/Wallet</directory>
            <directory>Modules/Payment</directory>
            <directory>Modules/Sms</directory>
            <directory>Modules/Geo</directory>
            <directory>Modules/Jobs</directory>
            <directory>Modules/Cms</directory>
            <directory>Modules/Support</directory>
            <directory>Modules/Marketplace</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="PAYMENT_DRIVER" value="testing"/>
    </php>
</phpunit>
